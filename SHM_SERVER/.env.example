# Copy this file to `.env` and adjust the values. Never commit your real `.env`.

# Flask secret key — use a long random value in production.
SECRET_KEY=dev-secret-change-in-production

# Flask debug mode (true/false). Keep this false in production.
FLASK_DEBUG=true

# Database connection string. Default is a local SQLite file.
# For production, use something like:
#   postgresql://user:password@localhost/shm_db
DATABASE_URL=sqlite:///shm.db

# Optional: Google Gemini API key to enable the AI analyst service.
# Leave blank to keep AI analysis disabled.
GEMINI_API_KEY=
